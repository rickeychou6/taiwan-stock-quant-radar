# Optional environment variables for future paid/self-hosted features.
# The current free deployment does not require any of these.
#
# DATABASE_URL=
# REDIS_URL=
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=
# OPENAI_API_KEY=
# FINMIND_API_TOKEN=
# DATA_PROVIDER_MODE=real

# Required only if the website should update AI paper-trader cloud settings
# such as the day-trading switch from the UI. Use a free GitHub fine-grained
# token with contents read/write permission to this repository.
# AUTO_TRADER_STATE_TOKEN=

# Optional: protect the settings PATCH endpoint. If set, clients must send
# x-auto-trader-admin-key with the same value.
# AUTO_TRADER_ADMIN_KEY=
